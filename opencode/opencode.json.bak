{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "share": "disabled",
    "provider": {
        "portkey": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "PortKey",
            "options": {
                "baseURL": "https://llm-gateway.xgw.xero-test.com/v1"
            },
            "models": {
                "@openai/o4-mini": {
                    "name": "o4-mini",
                    "contextWindow": 128000
                },
                "@openai/o3": {
                    "name": "o3",
                    "contextWindow": 128000
                },
                "@openai/gpt-5.4-pro": {
                    "name": "GPT-5.4 Pro",
                    "contextWindow": 128000
                },
                "@openai/gpt-5.4": {
                    "name": "GPT-5.4",
                    "contextWindow": 128000
                },
                "@openai/gpt-5.2-codex": {
                    "name": "GPT-5.2 Codex",
                    "contextWindow": 128000
                },
                "@openai/gpt-5.2": {
                    "name": "GPT-5.2",
                    "contextWindow": 128000
                },
                "@openai/gpt-5-nano": {
                    "name": "GPT-5 Nano",
                    "contextWindow": 128000
                },
                "@openai/gpt-5-mini": {
                    "name": "GPT-5 Mini",
                    "contextWindow": 128000
                },
                "@openai/gpt-5": {
                    "name": "GPT-5",
                    "contextWindow": 128000
                },
                "@openai/gpt-4.1": {
                    "name": "GPT-4.1",
                    "contextWindow": 128000
                },
                "@bedrock/global.anthropic.claude-sonnet-4-5-20250929-v1:0": {
                    "name": "Claude Sonnet 4.5 (20250929)",
                    "contextWindow": 200000
                },
                "@bedrock/global.anthropic.claude-sonnet-4-6": {
                    "name": "Claude Sonnet 4.6",
                    "contextWindow": 200000
                },
                "@bedrock/global.anthropic.claude-opus-4-6-v1": {
                    "name": "Claude Opus 4.6",
                    "contextWindow": 200000
                },
                "@bedrock/global.anthropic.claude-opus-4-5-20251101-v1:0": {
                    "name": "Claude Opus 4.5 (20251101)",
                    "contextWindow": 200000
                },
                "@bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0": {
                    "name": "Claude Haiku 4.5 (20251001)",
                    "contextWindow": 200000
                },
                "@vertexai/gemini-embedding-001": {
                    "name": "Gemini Embedding 001",
                    "contextWindow": 8192
                },
                "@vertexai/gemini-3.1-pro-preview": {
                    "name": "Gemini 3.1 Pro Preview",
                    "contextWindow": 2000000
                },
                "@vertexai/gemini-3.1-flash-lite-preview": {
                    "name": "Gemini 3.1 Flash Lite Preview",
                    "contextWindow": 1000000
                },
                "@vertexai/gemini-3-pro-preview": {
                    "name": "Gemini 3.0 Pro Preview",
                    "contextWindow": 2000000
                },
                "@vertexai/gemini-2.5-pro": {
                    "name": "Gemini 2.5 Pro",
                    "contextWindow": 2000000
                },
                "@vertexai/gemini-2.5-flash-lite": {
                    "name": "Gemini 2.5 Flash Lite",
                    "contextWindow": 1000000
                },
                "@vertexai/gemini-2.5-flash": {
                    "name": "Gemini 2.5 Flash",
                    "contextWindow": 1000000
                },
                "@bedrock/amazon.titan-embed-text-v2:0": {
                    "name": "Amazon Titan Embed Text v2.0",
                    "contextWindow": 8192
                },
                "@bedrock/amazon.titan-embed-text-v1": {
                    "name": "Amazon Titan Embed Text v1",
                    "contextWindow": 8192
                }
            }
        }
    },
    "agent": {
        "compaction": {
            "model": "@openai/gpt-5-mini"
        },
        "explore": {
            "model": "@bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0"
        },
        "doc-writer": {
            "description": "Writes boilerplate documentation and inline comments",
            "mode": "subagent",
            "model": "@bedrock/global.anthropic.claude-haiku-4-5-20251001-v1:0",
            "prompt": "You are a documentation assistant. Add clear inline comments and docstrings to the provided code. Do not change the underlying logic.",
            "permission": {
                "bash": "deny"
            }
        },
        "formatter": {
            "description": "Handles menial formatting, linting, and basic syntax cleanup tasks",
            "mode": "subagent",
            "model": "@vertexai/gemini-2.5-flash-lite",
            "prompt": "You are a code formatter and cleanup assistant. Focus only on fixing formatting, typos, and simple syntax errors without making architectural changes.",
            "permission": {
                "bash": "deny"
            }
        },
        "quick-helper": {
            "description": "Fast assistant for simple questions and quick menial edits",
            "mode": "subagent",
            "model": "@openai/gpt-5-mini",
            "prompt": "You are a fast, helpful assistant for menial tasks. Keep answers concise.",
            "permission": {
                "edit": "ask",
                "bash": "deny"
            }
        }
    }
}
