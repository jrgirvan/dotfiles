  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "agent": {
    "compaction": {
      "mode": "subagent",
      "model": "portkey/@openai/gpt-5.4-nano"
    },
    "build": {
      "mode": "primary",
      "model": "portkey/@openai/gpt-5.4",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "plan": {
      "mode": "primary",
      "model": "portkey/@openai/gpt-5.4",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "general": {
      "mode": "subagent",
      "model": "portkey/@openai/gpt-5.4-mini"
    },
    "explore": {
      "mode": "subagent",
      "model": "portkey/@openai/gpt-5.4-mini"
    }
  }
